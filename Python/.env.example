# Environment Configuration Template
# Copy this file to .env and update with your actual values

# ===== APPLICATION SETTINGS =====
LOG_LEVEL=INFO
DEBUG=False
PYTHONUNBUFFERED=1

# ===== DATABASE CONFIGURATION =====
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://cleanup:cleanup@localhost:5432/cleanup
# Or MySQL
# DATABASE_URL=mysql+pymysql://cleanup:cleanup@localhost:3306/cleanup

# Database connection pool
DATABASE_POOL_SIZE=10
DATABASE_ECHO=False  # Set to True for SQL debugging

# ===== SECURITY =====
SECRET_KEY=change-me-to-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# API Keys (if using external services)
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# ===== FILE UPLOAD SETTINGS =====
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS=csv,json
UPLOAD_FOLDER=./data/uploads

# ===== FUZZY MATCHING SETTINGS =====
FUZZY_THRESHOLD=0.8
FUZZY_ALGORITHM=WRatio
BLOCK_SIZE=1000  # For large dataset optimization

# ===== PERFORMANCE SETTINGS =====
WORKER_PROCESSES=4
MAX_WORKERS=10
REQUEST_TIMEOUT=300
BATCH_SIZE=1000

# ===== LOGGING SETTINGS =====
LOG_DIR=./logs
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ===== STREAMLIT SETTINGS =====
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=false
STREAMLIT_LOGGER_LEVEL=info

# ===== REDIS CACHE (optional) =====
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ===== EMAIL NOTIFICATIONS (optional) =====
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# ===== EXTERNAL SERVICES (optional) =====
# Sentry (error tracking)
SENTRY_ENVIRONMENT=development

# Google Analytics (if added later)
GA_TRACKING_ID=

# ===== DEPLOYMENT ENVIRONMENT =====
ENVIRONMENT=development  # development, staging, production
